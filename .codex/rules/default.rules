prefix_rule(pattern=["git", "fetch", "--all", "--prune"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "python - <<'PY'\nimport json\nfrom pathlib import Path\nimport urllib.request\n\nschema_path = Path('/Users/mao/code/CopyTradingCodex/server/db/schema.sql')\nif not schema_path.exists():\n    print('MISSING_SCHEMA')\n    raise SystemExit(0)\n\nenv_path = Path('/Users/mao/code/CopyTradingCodex/.env')\nurl = None\nkey = None\nfor line in env_path.read_text().splitlines():\n    if line.strip().startswith('SUPABASE_URL='):\n        url = line.split('=', 1)[1].strip()\n    if line.strip().startswith('SUPABASE_SECRET_KEY='):\n        key = line.split('=', 1)[1].strip()\n\nif not url or not key:\n    print('MISSING_ENV_VALUES')\n    raise SystemExit(0)\n\nsql = schema_path.read_text()\nheaders = {\n    'apikey': key,\n    'Authorization': f'Bearer {key}',\n    'Content-Type': 'application/json',\n    'Accept': 'application/json',\n}\n\ncandidates = [\n    '/rest/v1/rpc/exec_sql',\n    '/rest/v1/rpc/execute_sql',\n]\n\nresults = []\nfor endpoint in candidates:\n    req = urllib.request.Request(\n        url.rstrip('/') + endpoint,\n        data=json.dumps({'sql': sql}).encode('utf-8'),\n        headers=headers,\n        method='POST',\n    )\n    try:\n        with urllib.request.urlopen(req, timeout=15) as resp:\n            body = resp.read().decode('utf-8')\n            results.append({'endpoint': endpoint, 'ok': True, 'status': resp.status, 'body': body[:200]})\n            break\n    except Exception as e:\n        results.append({'endpoint': endpoint, 'ok': False, 'error': str(e).split('\\n')[0]})\n\nprint(json.dumps(results, ensure_ascii=False, indent=2))\nPY"], decision="allow")
prefix_rule(pattern=["git", "add", "."], decision="allow")
prefix_rule(pattern=["git", "remote", "add", "origin", "git@github.com:maorenxin/CopyTradingCodex.git"], decision="allow")
