2025-12-24T02:51:05.206758Z  INFO ToolCall: shell_command {"command":"cat <<'EOF' > /Users/mao/code/CopyTradingCodex/specs/001-copytrade-platform/contracts/openapi.yaml\nopenapi: 3.0.3\ninfo:\n  title: 跟单平台 API\n  version: 0.1.0\n  description: Web 与 Telegram 共用的核心数据与跟单接口契约。\nservers:\n  - url: https://api.example.com\npaths:\n  /traders:\n    get:\n      summary: 获取交易员列表\n      parameters:\n        - in: query\n          name: view\n          schema:\n            type: string\n            enum: [card, table]\n        - in: query\n          name: sort\n          schema:\n            type: string\n            enum: [sharpe, all_time_return, max_drawdown, win_rate]\n        - in: query\n          name: order\n          schema:\n            type: string\n            enum: [asc, desc]\n        - in: query\n          name: lang\n          schema:\n            type: string\n            enum: [zh, en]\n      responses:\n        '200':\n          description: 交易员列表\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/TraderList'\n  /traders/{traderId}:\n    get:\n      summary: 获取交易员详情\n      parameters:\n        - in: path\n          name: traderId\n          required: true\n          schema:\n            type: string\n      responses:\n        '200':\n          description: 交易员详情\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/TraderDetail'\n  /traders/{traderId}/metrics:\n    get:\n      summary: 获取交易员指标\n      parameters:\n        - in: path\n          name: traderId\n          required: true\n          schema:\n            type: string\n        - in: query\n          name: window\n          schema:\n            type: string\n            enum: [7d, 30d, 90d, all]\n      responses:\n        '200':\n          description: 指标数据\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/PerformanceMetric'\n  /traders/{traderId}/trades:\n    get:\n      summary: 获取交易历史\n      parameters:\n        - in: path\n          name: traderId\n          required: true\n          schema:\n            type: string\n        - in: query\n          name: limit\n          schema:\n            type: integer\n            default: 50\n        - in: query\n          name: cursor\n          schema:\n            type: string\n      responses:\n        '200':\n          description: 交易历史列表\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/TradeHistoryList'\n  /traders/{traderId}/equity:\n    get:\n      summary: 获取净值走势与 BTC 对比\n      parameters:\n        - in: path\n          name: traderId\n          required: true\n          schema:\n            type: string\n        - in: query\n          name: window\n          schema:\n            type: string\n            enum: [7d, 30d, 90d, all]\n      responses:\n        '200':\n          description: 净值与 BTC 对比曲线\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/EquitySeries'\n  /copy-orders:\n    post:\n      summary: 创建跟单订单\n      requestBody:\n        required: true\n        content:\n          application/json:\n            schema:\n              $ref: '#/components/schemas/CopyOrderCreate'\n      responses:\n        '200':\n          description: 跟单订单创建结果\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/CopyOrder'\n  /copy-orders/{orderId}:\n    get:\n      summary: 获取跟单订单详情\n      parameters:\n        - in: path\n          name: orderId\n          required: true\n          schema:\n            type: string\n      responses:\n        '200':\n          description: 跟单订单详情\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/CopyOrder'\n  /copy-orders/{orderId}/cancel:\n    post:\n      summary: 撤单\n      parameters:\n        - in: path\n          name: orderId\n          required: true\n          schema:\n            type: string\n      responses:\n        '200':\n          description: 撤单结果\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/CopyOrder'\n  /portfolio:\n    get:\n      summary: 获取用户资产与跟单概览\n      parameters:\n        - in: query\n          name: wallet\n          required: true\n          schema:\n            type: string\n      responses:\n        '200':\n          description: 资产概览\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/PortfolioSummary'\n  /telegram/webhook:\n    post:\n      summary: Telegram 更新回调入口\n      requestBody:\n        required: true\n        content:\n          application/json:\n            schema:\n              $ref: '#/components/schemas/TelegramUpdate'\n      responses:\n        '200':\n          description: 回调处理成功\n  /telegram/bind:\n    post:\n      summary: 生成绑定深链\n      requestBody:\n        required: true\n        content:\n          application/json:\n            schema:\n              $ref: '#/components/schemas/TelegramBindRequest'\n      responses:\n        '200':\n          description: 返回深链与绑定会话\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/TelegramBindResponse'\n  /telegram/bind/confirm:\n    post:\n      summary: 确认绑定完成\n      requestBody:\n        required: true\n        content:\n          application/json:\n            schema:\n              $ref: '#/components/schemas/TelegramBindConfirm'\n      responses:\n        '200':\n          description: 绑定确认结果\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/TelegramBindResponse'\n\ncomponents:\n  schemas:\n    TraderList:\n      type: object\n      properties:\n        items:\n          type: array\n          items:\n            $ref: '#/components/schemas/TraderSummary'\n    TraderSummary:\n      type: object\n      properties:\n        id:\n          type: string\n        address:\n          type: string\n        display_name:\n          type: string\n        metrics:\n          $ref: '#/components/schemas/PerformanceMetric'\n    TraderDetail:\n      type: object\n      properties:\n        id:\n          type: string\n        address:\n          type: string\n        display_name:\n          type: string\n        metrics:\n          $ref: '#/components/schemas/PerformanceMetric'\n        risk_notice:\n          type: string\n    PerformanceMetric:\n      type: object\n      properties:\n        window:\n          type: string\n          enum: [7d, 30d, 90d, all]\n        return_rate:\n          type: number\n        sharpe:\n          type: number\n        win_rate:\n          type: number\n        max_drawdown:\n          type: number\n        pnl:\n          type: number\n    TradeHistoryList:\n      type: object\n      properties:\n        items:\n          type: array\n          items:\n            $ref: '#/components/schemas/TradeHistory'\n        next_cursor:\n          type: string\n    TradeHistory:\n      type: object\n      properties:\n        tx_hash:\n          type: string\n        side:\n          type: string\n        size:\n          type: number\n        price:\n          type: number\n        pnl:\n          type: number\n        timestamp:\n          type: string\n          format: date-time\n    EquitySeries:\n      type: object\n      properties:\n        points:\n          type: array\n          items:\n            $ref: '#/components/schemas/EquityPoint'\n    EquityPoint:\n      type: object\n      properties:\n        timestamp:\n          type: string\n          format: date-time\n        vault_equity:\n          type: number\n        btc_equity:\n          type: number\n    CopyOrderCreate:\n      type: object\n      required: [wallet_address, trader_id, amount_usdc]\n      properties:\n        wallet_address:\n          type: string\n        trader_id:\n          type: string\n        amount_usdc:\n          type: number\n    CopyOrder:\n      type: object\n      properties:\n        id:\n          type: string\n        wallet_address:\n          type: string\n        trader_id:\n          type: string\n        amount_usdc:\n          type: number\n        fee_usdc:\n          type: number\n        status:\n          type: string\n          enum: [pending, active, cancelled, failed]\n    PortfolioSummary:\n      type: object\n      properties:\n        wallet_address:\n          type: string\n        total_value:\n          type: number\n        active_orders:\n          type: integer\n        pnl:\n          type: number\n    TelegramUpdate:\n      type: object\n      properties:\n        update_id:\n          type: integer\n        message:\n          type: object\n    TelegramBindRequest:\n      type: object\n      required: [telegram_user_id]\n      properties:\n        telegram_user_id:\n          type: string\n    TelegramBindResponse:\n      type: object\n      properties:\n        bind_id:\n          type: string\n        bind_url:\n          type: string\n        status:\n          type: string\n          enum: [pending, verified]\n    TelegramBindConfirm:\n      type: object\n      required: [bind_id, wallet_address, signature]\n      properties:\n        bind_id:\n          type: string\n        wallet_address:\n          type: string\n        signature:\n          type: string\nEOF","workdir":"/Users/mao/code/CopyTradingCodex"}
